exec swayidle -w \
    timeout 570 'swaymsg "output * dpms off"' \
    resume 'swaymsg "output * dpms on"' \
    timeout 600 'swaylock -f --clock --indicator --screenshots --effect-scale 0.2 --effect-vignette 0.3:0.8 \
                             --effect-blur 2x1 --datestr "%a %e.%m.%Y" --timestr "%k:%M"' \
    timeout 660 'systemctl suspend' \
    before-sleep 'swaylock -f --clock --indicator --screenshots --effect-scale 0.2 --effect-vignette 0.3:0.8 \
                              --effect-blur 2x1 --datestr "%a %e.%m.%Y" --timestr "%k:%M"'
